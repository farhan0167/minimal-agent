# Copy this file to `.env` and fill in the values you need.
# Unset variables fall back to the defaults in config.py.

# --- Backend selection -------------------------------------------------------
# Which provider LLM(...) talks to. One of: openai | openrouter | anthropic.
# "openrouter" and "anthropic" both use the OpenAI SDK against those providers'
# OpenAI-compatible endpoints. Caveats in llm/llm.py.
LLM_BACKEND=openai

# --- Backend credentials -----------------------------------------------------
# API key for whichever backend is active. For OpenAI this is your OpenAI key,
# for OpenRouter your OpenRouter key, for Anthropic your Anthropic key.
#
# If unset, falls back to the conventional env var for the active backend
# (OPENAI_API_KEY, OPENROUTER_API_KEY, ANTHROPIC_API_KEY).
LLM_BACKEND_API_KEY=sk-...

# Optional: shown on OpenRouter's public leaderboards. Ignored by other backends.
# LLM_BACKEND_SITE_URL=https://your-app.example.com
# LLM_BACKEND_APP_NAME=your-app

# --- Client overrides --------------------------------------------------------
# Per-request timeout in seconds (float). Leave unset for the SDK default.
# OPENAI_TIMEOUT=30

# How many times the SDK should retry failed requests. Leave unset for default.
# OPENAI_MAX_RETRIES=2

# --- Model selection ---------------------------------------------------------
# Default model name passed to LLM(model=...).
# Examples per backend:
#   openai      -> gpt-4o-mini
#   openrouter  -> anthropic/claude-opus-4-5, openai/gpt-4o-mini, ...
#   anthropic   -> claude-opus-4-6, claude-sonnet-4-6
LLM_MODEL=gpt-4o-mini
