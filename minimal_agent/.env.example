# Copy this file to `.env` and fill in the values you need.
# Unset variables fall back to the defaults in config.py.

# --- OpenAI / OpenAI-compatible client ---------------------------------------

# API key. Required for api.openai.com; often a dummy value (e.g. "sk-local")
# is fine for local servers like llama.cpp or LM Studio.
OPENAI_API_KEY=sk-...

# Override to point at an OpenAI-compatible server. Leave unset for OpenAI.
# Examples:
#   http://localhost:8000/v1        (vLLM, llama.cpp --api)
#   http://localhost:1234/v1        (LM Studio)
#   http://localhost:11434/v1       (Ollama)
# OPENAI_BASE_URL=

# Per-request timeout in seconds (float). Leave unset for the SDK default.
# OPENAI_TIMEOUT=30

# How many times the SDK should retry failed requests. Leave unset for default.
# OPENAI_MAX_RETRIES=2

# --- Model selection ---------------------------------------------------------

# Default model name passed to LLM(model=...).
LLM_MODEL=gpt-4o-mini
